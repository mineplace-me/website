{
  "name": "mineplace-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "cd packages/bluemap && vp run build && cd ../mineplace && vp run build",
    "start": "cd packages/bluemap && vp run build && cd ../mineplace && vp run start",
    "serve": "cd packages/mineplace && vp serve",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@nx/js": "^22.7.1",
    "nx": "22.7.1",
    "tsx": "^4.21.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "yargs": "^18.0.0"
  },
  "overrides": {
    "vite": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ]
}
