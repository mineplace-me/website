{
  "name": "mineplace",
  "description": "Main Mineplace website",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/bun/vite.config.ts",
    "build.types": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "serve": "bun server/entry.bun.js",
    "start": "vite --open --mode ssr --host",
    "start.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --forcenode --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@anuragroy/tailwindcss-animate": "^1.0.6",
    "@eslint/js": "latest",
    "@luminescent/icons-qwik": "0.1.1",
    "@luminescent/ui": "^7.0.0",
    "@luminescent/ui-qwik": "7.0.0-0",
    "@qwik.dev/core": "2.0.0-beta.31",
    "@qwik.dev/router": "2.0.0-beta.31",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "*",
    "eslint": "10.3.0",
    "eslint-plugin-qwik": "2.0.0-beta.31",
    "globals": "17.6.0",
    "lucide-icons-qwik": "1.7.0-qwik-v2",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-icons-qwik": "16.12.0-qwik-v2",
    "tailwindcss": "^4.2.4",
    "ts-morph": "^27.0.2",
    "typescript": "5",
    "typescript-eslint": "8.59.1",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "peerDependencies": {
    "bluemap": "workspace:*"
  }
}
