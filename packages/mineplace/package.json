{
  "name": "mineplace",
  "private": true,
  "description": "Main Mineplace website",
  "type": "module",
  "scripts": {
    "build": "vp run build.types && vp run build.client && vp run build.server && vp run lint",
    "build.client": "vp build",
    "build.preview": "vp build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vp build -c adapters/bun/vite.config.ts",
    "build.types": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "vp lint",
    "preview": "vp run build.types && vp run build.client && vp run build.preview && vp preview --open",
    "serve": "bun server/entry.bun.js",
    "start": "vp dev --open --mode ssr --host",
    "start.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --forcenode --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@anuragroy/tailwindcss-animate": "^1.0.6",
    "@luminescent/icons-qwik": "0.1.1",
    "@luminescent/ui": "^7.0.2",
    "@luminescent/ui-qwik": "7.0.0-20",
    "@qwik.dev/core": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/core@8785",
    "@qwik.dev/router": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/router@8785",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "*",
    "globals": "17.6.0",
    "lucide-icons-qwik": "1.24.0-qwik-v2",
    "oxlint-plugin-qwik": "^0.0.9",
    "simple-icons-qwik": "16.19.0-qwik-v2",
    "tailwindcss": "^4.3.0",
    "ts-morph": "^28.0.0",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "bluemap": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
